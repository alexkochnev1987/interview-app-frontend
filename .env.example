# Copy to ".env.local" for local development (never commit secrets).

NEXT_PUBLIC_ENV=local

# Used by next.config.js rewrites: browser calls /api/* → this backend origin.
BACKEND_URL=http://localhost:3000

# E2E (Playwright) — optional overrides; defaults match local bootstrap user.
# E2E_BASE_URL=http://localhost:3001
# E2E_EMAIL=admin@interview-app.com
# E2E_PASSWORD=admin123
# BACKEND_REPO_PATH=../interview-app-backend
