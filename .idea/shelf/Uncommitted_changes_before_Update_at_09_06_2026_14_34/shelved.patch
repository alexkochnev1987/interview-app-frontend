<+>name: Frontend CI\r\n\r\non:\r\n  push:\r\n    branches: [develop, main]\r\n  pull_request:\r\n    branches: [develop, main]\r\n  workflow_dispatch:\r\n\r\njobs:\r\n  test:\r\n    runs-on: ubuntu-latest\r\n    steps:\r\n      - uses: actions/checkout@v4\r\n      - uses: actions/setup-node@v4\r\n        with:\r\n          node-version: '22'\r\n      - run: npm ci\r\n      - name: Regenerate OpenAPI types from committed spec\r\n        run: npm run openapi:generate\r\n      - name: Ensure generated types match committed spec\r\n        run: git diff --exit-code -- src/lib/api-types.ts\r\n      - run: npm run lint:ci\r\n      - run: npm run test\r\n      - run: npx next build --webpack\r\n      - name: Upload production build for E2E\r\n        uses: actions/upload-artifact@v4\r\n        with:\r\n          name: next-build\r\n          path: .next\r\n          include-hidden-files: true\r\n          retention-days: 1\r\n\r\n  e2e:\r\n    needs: test\r\n    runs-on: ubuntu-latest\r\n    env:\r\n      CI: true\r\n      BACKEND_URL: http://localhost:3000\r\n      E2E_BASE_URL: http://localhost:3001\r\n      E2E_PREBUILT: '1'\r\n    steps:\r\n      - uses: actions/checkout@v4\r\n      - uses: actions/setup-node@v4\r\n        with:\r\n          node-version: '22'\r\n      - run: npm ci\r\n      - name: Download production build\r\n        uses: actions/download-artifact@v4\r\n        with:\r\n          name: next-build\r\n          path: .next\r\n      - name: Install Playwright Chromium\r\n        run: npm run test:e2e:install\r\n      - name: Run E2E smoke tests\r\n        run: npm run test:e2e\r\n\r\n# Deploy is handled by AWS Amplify auto-build (connected to GitHub repo).\r\n# Amplify watches develop → dev, main → prod and builds automatically.\r\n
