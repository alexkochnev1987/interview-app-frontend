{
  "name": "interview-app-frontend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "npm run openapi:refresh && next dev -p 3001",
    "build": "npm run openapi:generate && next build --webpack",
    "start": "next start",
    "lint": "eslint .",
    "openapi:backend:generate": "node scripts/generate-backend-openapi.mjs",
    "openapi:sync": "node scripts/sync-openapi.mjs",
    "openapi:generate": "npx --yes openapi-typescript openapi/openapi.json -o src/lib/api-types.ts",
    "openapi:refresh": "npm run openapi:backend:generate && npm run openapi:sync && npm run openapi:generate"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.100.11",
    "@tanstack/react-query-devtools": "^5.100.11",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.8.0",
    "next": "^16.2.4",
    "openapi-fetch": "^0.17.0",
    "radix-ui": "^1.4.3",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.5.0",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.4",
    "openapi-typescript": "^7.13.0",
    "postcss": "^8.5.10",
    "tailwindcss": "^3.4.17",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^5.0.0"
  }
}
