{
  "name": "interview-app-frontend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "npm run openapi:refresh && npm run dev:server",
    "dev:server": "next dev -p 3001 --webpack",
    "build": "npm run openapi:generate && next build --webpack",
    "start": "next start",
    "lint": "eslint .",
    "i18n:check": "node scripts/i18n-check-parity.mjs",
    "lint:ci": "npm run lint && npm run i18n:check",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "node scripts/e2e-run.mjs",
    "test:e2e:fast": "node scripts/e2e-run.mjs --fast",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:install": "playwright install chromium",
    "verify:ci": "node scripts/verify-ci.mjs",
    "openapi:backend:generate": "node scripts/generate-backend-openapi.mjs",
    "openapi:sync": "node scripts/sync-openapi.mjs",
    "openapi:generate": "npx --yes openapi-typescript openapi/openapi.json -o src/lib/api-types.ts",
    "openapi:refresh": "npm run openapi:backend:generate && npm run openapi:sync && npm run openapi:generate"
  },
  "dependencies": {
    "@swc/helpers": "^0.5.23",
    "@tanstack/react-query": "^5.100.11",
    "@tanstack/react-query-devtools": "^5.100.11",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "driver.js": "^1.4.0",
    "lucide-react": "^1.8.0",
    "next": "^16.2.4",
    "next-intl": "^4.12.0",
    "openapi-fetch": "^0.17.0",
    "radix-ui": "^1.4.3",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/node": "^20.0.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.5.0",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.4",
    "openapi-typescript": "^7.13.0",
    "postcss": "^8.5.10",
    "tailwindcss": "^3.4.17",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^5.0.0",
    "vite": "^7.3.5",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.8"
  }
}
